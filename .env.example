# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI API endpoint
# Leave blank to use default OpenAI endpoint
OPENAI_BASE_URL=

# Embedding API Configuration (LiteLLM or other OpenAI-compatible endpoint)
# Defaults to OPENAI_API_KEY and OPENAI_BASE_URL when unset
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-large

# Vector Database Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=agent_sdr

# Parallel Processing Configuration
# Enable parallel processing for faster batch research (true/false)
# Default: false (sequential processing)
ENABLE_PARALLEL_PROCESSING=false

# Number of accounts to process concurrently (1-10)
# Conservative: 3, Moderate: 5, Aggressive: 8
# Default: 5
PROCESSING_CONCURRENCY=5

# Maximum retry attempts for rate limit errors (0-10)
# Default: 3
MAX_API_RETRIES=3

# Delay between account batches in milliseconds
# Default: 500
ACCOUNT_DELAY_MS=500
